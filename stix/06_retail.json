    {
      "type": "incident",
      "spec_version": "2.1",
      "id": "incident--850a4f12-24ab-4cc2-8ce2-a3cb0a57286e",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Retail Point-of-Sale Card Data Breach",
      "description": "Memory-scraping malware compromises POS terminals and exposes customer payment card data."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--acaf11fd-17d0-417a-a947-46d237afc9cd",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 1 - Fraud Reports",
      "content": "The payment processor notifies the retailer of increased fraudulent card activity linked to recent purchases at several stores."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--be369134-2f54-4352-811b-cba8e582c6f0",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 2 - Suspicious POS Traffic",
      "content": "Network monitoring detects unusual outbound encrypted traffic from POS terminals to an external host not used by approved payment services."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--27c34aa0-304d-4f5c-b5e9-0bd586898884",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 3 - Malware Confirmed",
      "content": "Forensic analysis confirms memory-scraping malware on multiple POS terminals. Cardholder data may have been collected before authorization messages were encrypted."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--5376de2d-d02e-47ec-9ce8-67a0e105daca",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 4 - Payment Processor Escalation",
      "content": "The payment processor requests immediate containment actions, transaction logs, affected store list, and a PCI-related incident response briefing."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--3c12df98-6f3d-4947-9b2c-27878563bf64",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Isolate Affected POS Terminals",
      "description": "Remove compromised POS systems from the network and route transactions through validated backup payment processes."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--e09f3ead-1c71-4c7e-9892-83fbbcb505df",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Perform PCI Incident Response",
      "description": "Coordinate forensic investigation, payment processor engagement, customer notification analysis, and compliance reporting."
    },
