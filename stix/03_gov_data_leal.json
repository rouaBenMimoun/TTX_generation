      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Government Procurement Data Leak",
      "description": "Sensitive procurement documents are leaked publicly following suspected insider exfiltration."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--054076ef-8f0d-4cbf-adcb-513ae29b39b0",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 1 - Public Disclosure",
      "content": "Journalists contact the department for comment after sensitive procurement documents appear on a public file-sharing site."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--8056f239-c6b3-4131-b7a5-2f7da6771dd3",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 2 - Internal Source Identified",
      "content": "The leaked files match documents stored in the internal procurement repository. Access logs show unusual bulk downloads by a procurement analyst."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--1f685a39-dc59-4aca-bd3c-b84092d44750",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 3 - USB Evidence",
      "content": "Endpoint logs show a personal USB storage device connected shortly after the bulk downloads. Several sensitive files were copied before the device was removed."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--1b3ee8d2-e48d-48ce-820e-69a425d60562",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 4 - Media and Legal Escalation",
      "content": "Media outlets publish details from the leaked procurement documents. Legal, HR, and senior leadership must coordinate public response, disciplinary process, and regulator notification."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--cd7c2af8-3dbc-4c0d-a16b-fd8447d6c703",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Disable Suspected Insider Access",
      "description": "Suspend user access, preserve evidence, and coordinate with HR and legal teams."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--c2395079-f864-48d1-86aa-28c560e8de4f",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Restrict Removable Media",
      "description": "Enforce removable media controls and audit sensitive file transfer activity."
    },
