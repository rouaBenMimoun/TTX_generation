      "name": "Compromised Vendor Update Incident",
      "description": "Manufacturing disruption caused by a malicious software update distributed through a trusted supplier."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--0f8f7d18-c932-4b4c-9e80-69d84bfa38a4",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 1 - Software Update Deployment",
      "content": "Operations teams deploy a newly released software update from a trusted industrial software supplier across production systems."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--d9c4bc8e-7ef3-48ab-8eb0-f8bb60d4cb82",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 2 - Production Instability",
      "content": "Multiple production lines begin experiencing unexpected stoppages and abnormal machine behavior following the software update."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--4dd0c59b-cd85-4909-8d7f-98c56f842c4f",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 3 - Malicious Communications Detected",
      "content": "Security monitoring identifies outbound encrypted communications from manufacturing systems to previously unseen external infrastructure."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--91d1fd38-648f-47fd-9fc5-3bc67e839b35",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 4 - Production Shutdown",
      "content": "Plant leadership orders a controlled shutdown of production systems while incident responders investigate the suspected supply chain compromise."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
