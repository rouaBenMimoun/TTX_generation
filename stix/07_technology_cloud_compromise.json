      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Cloud Administrator Account Compromise",
      "description": "Compromised cloud administrator account results in unauthorized IAM modifications and access to customer data."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--7f55f03d-c9c0-4d7a-92e0-1e1ef0d82c77",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 1 - Suspicious Cloud Activity",
      "content": "Cloud monitoring detects administrator API calls originating from a geographic region not previously associated with the organization."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--0c41afeb-f6e2-4fd4-bdc8-7e3a88df00cb",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 2 - IAM Modification",
      "content": "Investigation reveals creation of new privileged roles and modification of existing administrator permissions without authorization."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--7dc84b0f-3ea0-4f4e-a0d3-69a2b48fddf4",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 3 - Customer Data Access",
      "content": "Audit logs indicate unauthorized access to cloud storage containing customer information and application configuration data."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--f49b7f45-0e48-42c7-a81f-37bdbcbfc0ef",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 4 - Customer and Regulatory Notification",
      "content": "Executive leadership must determine breach notification requirements, customer communications, and engagement with regulators and cloud service providers."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--8a37c4a7-95f0-4f8f-9f16-c1b69b9cf83d",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Revoke Compromised Credentials",
      "description": "Disable compromised administrator accounts, rotate secrets, and terminate active sessions."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--f8aaf9e2-7d88-46d8-a6ef-4e2d9af4c6a9",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Review Cloud IAM and Storage Access",
      "description": "Audit privileged roles, remove unauthorized permissions, and review cloud storage access logs."
    },
