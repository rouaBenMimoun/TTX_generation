      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Telecommunications Customer Portal DDoS",
      "description": "Large-scale DDoS attack disrupts customer-facing telecommunications services."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--ad4667c1-920f-4395-93d8-bde04d30d316",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 1 - Portal Unavailable",
      "content": "Customers report that the self-service portal is unavailable. Call center volume increases sharply as users cannot access billing and account services."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--9ec0c1e0-1983-47c5-bf13-6c92928cad3d",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 2 - Traffic Spike",
      "content": "Network operations observes a traffic spike exceeding normal baseline by more than 500 percent, with high-volume requests from distributed global sources."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--4ac41149-76d4-4265-b482-7abcb54430cd",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 3 - Botnet Indicators",
      "content": "Security teams identify botnet-like traffic patterns, including repeated HTTP requests, spoofed headers, and source diversity across residential networks."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--03ca23da-30c5-499d-8910-c5e969a2191c",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 4 - Filtering and Communications",
      "content": "Emergency traffic filtering is enabled with upstream providers. Communications teams prepare customer messaging about degraded online services."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--b5581f5c-3515-4a2e-98b7-6c42f29c1435",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Activate DDoS Mitigation",
      "description": "Route traffic through scrubbing services, apply rate limits, and coordinate filtering with upstream network providers."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--e7fc61c3-a29b-49d3-a0e6-bfdaf72e67c4",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Customer Communications Response",
      "description": "Issue service advisories, update status pages, and provide alternate support channels."
    },
