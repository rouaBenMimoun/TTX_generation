      "id": "incident--6d5d1837-90b5-4434-8571-a98bcb6e7e16",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "University MFA Phishing and Student Records Exposure",
      "description": "Credential phishing campaign results in unauthorized access to university systems and possible exposure of student records."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--53e5c7b3-5a4d-4d30-a7b2-91236c435df2",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 1 - MFA Reset Phishing",
      "content": "Students and faculty report emails claiming that MFA enrollment will expire unless they reset their authentication settings through an embedded link."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--2d5d8730-3bdf-4a7e-9e7d-4a0fe10af072",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 2 - Fake Login Portal",
      "content": "IT identifies a fake university login portal collecting usernames, passwords, and MFA prompts from victims."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--9a9cf978-8033-41bc-961f-07a82e99b9d28",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 3 - Records Accessed",
      "content": "Audit logs show compromised student accounts used to access academic records and financial aid documents."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--5bfd939b-42af-4e84-85fc-0715cbb8dd09",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 4 - Campus-Wide Response",
      "content": "University leadership authorizes a forced password reset, MFA token review, student notification planning, and law enforcement coordination."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--8c38a5cd-0704-4e39-b64e-1980637ae399",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Revoke Compromised Sessions",
      "description": "Revoke active sessions, reset affected credentials, and review MFA token registrations."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
