      "name": "Medical Imaging Malware Disruption",
      "description": "Malware disrupts hospital imaging services and affects patient care operations."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--36b810d2-7389-49d3-9899-081d7f627d0f",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 1 - Suspicious Workstation Activity",
      "content": "A radiology scheduling clerk reports opening an invoice attachment. Endpoint monitoring detects suspicious PowerShell activity on the workstation."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--e58fd2f7-1779-4697-b6f6-38366d9410d3",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 2 - Imaging Workflow Disruption",
      "content": "CT and MRI workstations begin rebooting unexpectedly. Clinicians cannot reliably access imaging results through the PACS viewer."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--bcc23813-c897-452a-8ef6-b8ee9b74acee",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 3 - Malware Confirmed",
      "content": "Security analysts confirm malware on systems connected to the radiology imaging network. Network segmentation gaps may have allowed spread from administrative systems."
    },
    {
      "type": "note",
      "spec_version": "2.1",
      "id": "note--35661c16-b82d-4b7e-ac4c-2f3e6d95d86c",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "abstract": "Inject 4 - Patient Care Escalation",
      "content": "Emergency department leadership considers diverting trauma patients to nearby hospitals because urgent imaging availability is unreliable."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--f5ee9452-8a12-4401-a4e2-2b7d0a03f3c6",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Isolate Clinical Imaging Network",
      "description": "Restrict connectivity between administrative systems and radiology infrastructure."
    },
    {
      "type": "course-of-action",
      "spec_version": "2.1",
      "id": "course-of-action--7a25d6bd-d1e7-49fd-b761-9d6357150afd",
      "created": "2026-06-22T00:00:00.000Z",
      "modified": "2026-06-22T00:00:00.000Z",
      "name": "Activate Patient Care Downtime Procedures",
      "description": "Use manual clinical workflows and diversion protocols where necessary."
    },
